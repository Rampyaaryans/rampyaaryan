kaam summary() {
    likho "\n=== ALL FEATURES WORKING ==="
    likho "  7 Data Types"
    likho "  30+ String Functions"
    likho "  20+ Math Functions"
    likho "  15+ List Functions"
    likho "  10+ Map Functions"
    likho "  6 Bitwise Operators"
    likho "  Type Conversions"
    likho "  Date/Time Functions"
    likho "  Closures & Higher-Order"
    likho "  Recursion Support"
    likho "  110+ Built-in Functions"
    likho "\nRampyaaryan - Powerful like Python!"
}
summary()
