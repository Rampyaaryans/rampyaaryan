likho "=== MULTI ASSIGN TEST ==="

likho "--- 1. Basic Multi Assign ---"
maano a, b, c = 10, 20, 30
likho a
likho b
likho c

likho "--- 2. String Multi Assign ---"
maano naam, umar, shehar = "Ram", 25, "Delhi"
likho naam
likho umar
likho shehar

likho "--- 3. Swap via Multi Assign ---"
maano x, y = 1, 2
likho x
likho y
maano x2, y2 = y, x
likho x2
likho y2

likho "--- 4. Expressions in Values ---"
maano p, q = 3 + 4, 5 * 6
likho p
likho q

likho "--- 5. Local Multi Assign ---"
kaam test() {
    maano a, b = 100, 200
    likho a + b
}
test()

likho "=== ALL MULTI ASSIGN TESTS PASSED ==="
