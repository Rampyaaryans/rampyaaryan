likho "=== IN OPERATOR & MAP ITERATION TEST ==="

likho "--- 1. 'mein' with Lists ---"
maano fruits = ["seb", "kela", "aam"]
likho "seb" mein fruits
likho "santara" mein fruits
likho 42 mein [10, 20, 42, 50]

likho "--- 2. 'mein' with Strings ---"
maano msg = "namaste duniya"
likho "namaste" mein msg
likho "xyz" mein msg
likho "duniya" mein msg

likho "--- 3. 'mein' with Maps ---"
maano person = {"naam": "Aryan", "umar": 25}
likho "naam" mein person
likho "xyz" mein person
likho "umar" mein person

likho "--- 4. 'mein' in Conditions ---"
maano list = [1, 2, 3, 4, 5]
agar 3 mein list {
    likho "3 mila!"
}
agar 99 mein list {
    likho "99 mila"
} warna {
    likho "99 nahi mila"
}

likho "--- 5. For-In on Maps ---"
maano colors = {"laal": "red", "neela": "blue", "hara": "green"}
har key mein colors {
    likho key
}

likho "--- 6. For-In on Maps with Values ---"
maano scores = {"math": 95, "science": 88, "hindi": 92}
har subject mein scores {
    likho subject
    likho scores[subject]
}

likho "--- 7. 'mein' with Enums ---"
ganana Level {
    LOW,
    MEDIUM,
    HIGH
}
likho "LOW" mein Level
likho "ULTRA" mein Level

likho "=== ALL IN/MAP TESTS PASSED ==="
