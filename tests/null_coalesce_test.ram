/* ===== NULL COALESCING TEST ===== */

likho("=== 1. Null Coalescing Basic ===")
maano a = khali
maano b = a ?? "default"
likho(b)

likho("=== 2. Non-null keeps value ===")
maano c = 42
maano d = c ?? 100
likho(d)

likho("=== 3. Chain ===")
maano x = khali
maano y = khali
maano z = x ?? y ?? "fallback"
likho(z)

likho("=== 4. With expressions ===")
maano val = khali ?? (10 + 20)
likho(val)

likho("=== ALL NULL COALESCING TESTS PASSED ===")
