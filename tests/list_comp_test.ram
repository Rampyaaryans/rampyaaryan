/* ===== LIST COMPREHENSION TEST ===== */

/* 1. Basic list comprehension */
likho("=== 1. Basic Comprehension ===")
maano nums = [1, 2, 3, 4, 5]
maano doubled = [har x mein nums : x * 2]
likho(doubled)

/* 2. With filter (agar) */
likho("=== 2. With Filter ===")
maano evens = [har x mein nums agar x % 2 == 0 : x]
likho(evens)

/* 3. Transform + filter */
likho("=== 3. Transform + Filter ===")
maano big_odds = [har x mein nums agar x % 2 != 0 : x * 10]
likho(big_odds)

/* 4. String operations */
likho("=== 4. String Ops ===")
maano words = ["hello", "world", "ram"]
maano upper = [har w mein words : bade_akshar(w)]
likho(upper)

/* 5. Nested expression */
likho("=== 5. Nested Expression ===")
maano squares = [har i mein [1, 2, 3, 4, 5] : i * i]
likho(squares)

/* 6. Empty result from filter */
likho("=== 6. Empty Result ===")
maano none = [har x mein nums agar x > 100 : x]
likho(none)
likho(lambai(none))

/* 7. With function call in expr */
likho("=== 7. Function in Expr ===")
kaam double(n) {
    wapas do n * 2
}
maano res = [har x mein [10, 20, 30] : double(x)]
likho(res)

likho("=== ALL LIST COMPREHENSION TESTS PASSED ===")
