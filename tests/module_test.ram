/* ===== MODULE IMPORT TEST ===== */

/* 1. Basic import */
likho("=== 1. Basic Import ===")
shamil karo "math_module.ram"
likho(square(5))
likho(cube(3))
likho(factorial(6))

/* 2. Imported constants */
likho("=== 2. Imported Constants ===")
likho(PI)
likho(E)

/* 3. Another module */
likho("=== 3. String Module ===")
shamil karo "string_module.ram"
likho(greet("Aryan"))
likho(repeat_str("Ha", 3))

/* 4. Duplicate import (should not re-execute) */
likho("=== 4. Duplicate Import ===")
shamil karo "math_module.ram"
likho(square(10))

likho("=== ALL MODULE TESTS PASSED ===")
