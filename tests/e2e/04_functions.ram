likho "=== TEST 04: Functions ==="

// Basic function
kaam add(a, b) {
    wapas do a + b
}
pakka add(3, 4) == 7, "basic function failed"

// Function with no return (returns null)
kaam no_return() {
    maano x = 42
}
pakka kya_khali(no_return()), "no return should give null"

// Recursion - factorial
kaam factorial(n) {
    agar n <= 1 { wapas do 1 }
    wapas do n * factorial(n - 1)
}
pakka factorial(0) == 1, "factorial 0 failed"
pakka factorial(1) == 1, "factorial 1 failed"
pakka factorial(5) == 120, "factorial 5 failed"
pakka factorial(10) == 3628800, "factorial 10 failed"

// Recursion - fibonacci
kaam fibo(n) {
    agar n <= 0 { wapas do 0 }
    agar n == 1 { wapas do 1 }
    wapas do fibo(n - 1) + fibo(n - 2)
}
pakka fibo(0) == 0, "fib 0 failed"
pakka fibo(1) == 1, "fib 1 failed"
pakka fibo(10) == 55, "fib 10 failed"

// Closures
kaam counter_banao() {
    maano count = 0
    kaam increment() {
        count = count + 1
        wapas do count
    }
    wapas do increment
}
maano c = counter_banao()
pakka c() == 1, "closure first call failed"
pakka c() == 2, "closure second call failed"
pakka c() == 3, "closure third call failed"

// Nested closures
kaam outer() {
    maano x = 10
    kaam middle() {
        maano y = 20
        kaam inner() {
            wapas do x + y
        }
        wapas do inner
    }
    wapas do middle
}
pakka outer()()() == 30, "nested closure failed"

// Lambda / anonymous functions
maano square = kaam (x) => x * x
pakka square(5) == 25, "lambda failed"

maano multiply = kaam (a, b) => a * b
pakka multiply(3, 4) == 12, "lambda with 2 args failed"

// Functions as arguments
kaam apply(func, val) {
    wapas do func(val)
}
pakka apply(kaam (x) => x * 2, 5) == 10, "function as argument failed"

// Functions returning functions
kaam multiplier(factor) {
    wapas do kaam (x) => x * factor
}
maano double = multiplier(2)
maano triple = multiplier(3)
pakka double(5) == 10, "returned function double failed"
pakka triple(5) == 15, "returned function triple failed"

// Early return
kaam find_first_even(nums) {
    har n mein nums {
        agar n % 2 == 0 {
            wapas do n
        }
    }
    wapas do -1
}
pakka find_first_even([1, 3, 4, 6]) == 4, "early return failed"
pakka find_first_even([1, 3, 5]) == -1, "no match return failed"

// Function checking
pakka kya_kaam(add), "kya_kaam for named function failed"
pakka kya_kaam(kaam (x) => x), "kya_kaam for lambda failed"

likho "✅ TEST 04 PASSED: Functions"
