/* ── Section 9: take_while / drop_while ── */
likho("=== Section 9: take_while/drop_while ===")
kaam less_than_4(x) { wapas do x < 4 }
likho(jab_tak_lo([1,2,3,5,1,2], less_than_4))
likho(jab_tak_chodo([1,2,3,5,1,2], less_than_4))

/* ── Section 10: find / find_index ── */
likho("=== Section 10: find/find_index ===")
kaam is_even(x) { wapas do x % 2 == 0 }
likho(dhundho_suchi([1,3,4,5,6], is_even))
likho(dhundho_index([1,3,4,5,6], is_even))

/* ── Section 11: group_by ── */
likho("=== Section 11: group_by ===")
kaam parity(x) { wapas do x % 2 }
maano groups = samuh([1,2,3,4,5,6], parity)
likho(groups)

