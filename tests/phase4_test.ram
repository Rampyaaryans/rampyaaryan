/* ── Section 1: str_starts_with / str_ends_with ── */
likho("=== Section 1: starts/ends ===")
likho(shuru_hai("Hello World", "Hello"))
likho(shuru_hai("Hello World", "World"))
likho(ant_hai("Hello World", "World"))
likho(ant_hai("Hello World", "Hello"))

/* ── Section 2: strip variants ── */
likho("=== Section 2: strip ===")
likho("[" + baya_saaf("  hello  ") + "]")
likho("[" + daya_saaf("  hello  ") + "]")

/* ── Section 3: string reverse / char_at / repeat ── */
likho("=== Section 3: str utils ===")
