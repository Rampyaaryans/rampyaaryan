/* ===== REST ARGUMENTS TEST ===== */

/* 1. Basic rest arguments */
likho("=== 1. Basic Rest Args ===")
kaam sum_all(...nums) {
    maano total = 0
    har i se 0 tak lambai(nums) - 1 {
        total = total + nums[i]
    }
    likho(total)
}
sum_all(1, 2, 3)
sum_all(10, 20, 30, 40, 50)
sum_all()

/* 2. Regular + rest params */
likho("=== 2. Regular + Rest ===")
kaam greet(greeting, ...names) {
    har i se 0 tak lambai(names) - 1 {
        likho(greeting + " " + names[i])
    }
}
greet("Namaste", "Aryan", "Ravi", "Priya")

/* 3. Rest param is a list */
likho("=== 3. Rest is List ===")
kaam show_type(...args) {
    likho(prakar(args))
    likho(lambai(args))
}
show_type(1, "hello", sach)

/* 4. Rest with no extra args = empty list */
likho("=== 4. Empty Rest ===")
kaam test_empty(a, ...rest) {
    likho(a)
    likho(lambai(rest))
}
test_empty(42)

/* 5. Passing rest to another function */
likho("=== 5. Pass Rest ===")
kaam multiply_all(...nums) {
    maano res = 1
    har i se 0 tak lambai(nums) - 1 {
        res = res * nums[i]
    }
    wapas do res
}
likho(multiply_all(2, 3, 4))
likho(multiply_all(5))

likho("=== ALL REST ARGS TESTS PASSED ===")
