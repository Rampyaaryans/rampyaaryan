/* ═══════════════════════════════════════════════
   Phase 3 Test — New Utility Native Functions
   ═══════════════════════════════════════════════ */

/* ── Section 1: tukda_shabd (string slice) ── */
likho("=== Section 1: tukda_shabd ===")
maano a = "Hello World"
likho(tukda_shabd(a, 0, 5))
likho(tukda_shabd(a, 6, 11))
likho(tukda_shabd(a, -5, lambai(a)))

/* ── Section 2: tukda_suchi (list slice) ── */
likho("=== Section 2: tukda_suchi ===")
maano s = [10, 20, 30, 40, 50]
maano s2 = tukda_suchi(s, 1, 4)
likho(s2)
maano s3 = tukda_suchi(s, -3, lambai(s))
likho(s3)

/* ── Section 3: enumerate_suchi ── */
likho("=== Section 3: enumerate_suchi ===")
maano items = ["a", "b", "c"]
maano en = enumerate_suchi(items)
likho(en)

/* ── Section 4: zip_suchi ── */
likho("=== Section 4: zip_suchi ===")
maano keys = [1, 2, 3]
maano vals = ["ek", "do", "teen"]
maano z = zip_suchi(keys, vals)
likho(z)

/* ── Section 5: unzip_suchi ── */
likho("=== Section 5: unzip_suchi ===")
maano paired = [[1, "a"], [2, "b"], [3, "c"]]
maano uz = unzip_suchi(paired)
likho(uz)

/* ── Section 6: char_list ── */
likho("=== Section 6: char_list ===")
maano chars = char_list("Ram")
likho(chars)

/* ── Section 7: suchi_se_shabd (join) ── */
likho("=== Section 7: suchi_se_shabd ===")
maano words = ["Ram", "pyaar", "yan"]
likho(suchi_se_shabd(words, "-"))
likho(suchi_se_shabd(words))

/* ── Section 8: map_keys_list / map_values_list ── */
likho("=== Section 8: map keys/values ===")
maano m = {"naam": "Aryan", "umar": 25}
maano mk = map_keys_list(m)
maano mv = map_values_list(m)
likho(mk)
likho(mv)

/* ── Section 9: suchi_mein (list contains) ── */
likho("=== Section 9: suchi_mein ===")
maano list1 = [10, 20, 30]
likho(suchi_mein(list1, 20))
likho(suchi_mein(list1, 99))

/* ── Section 10: shabd_mein (string contains) ── */
likho("=== Section 10: shabd_mein ===")
likho(shabd_mein("Hello World", "World"))
likho(shabd_mein("Hello World", "xyz"))

/* ── Section 11: min_suchi / max_suchi ── */
likho("=== Section 11: min/max ===")
maano nums = [5, 2, 8, 1, 9, 3]
likho(min_suchi(nums))
likho(max_suchi(nums))

/* ── Section 12: suchi_bharo (fill) ── */
likho("=== Section 12: suchi_bharo ===")
maano filled = suchi_bharo(5, 0)
likho(filled)

/* ── Section 13: sab_badlo (replace all) ── */
likho("=== Section 13: sab_badlo ===")
maano txt = "hello world hello"
likho(sab_badlo(txt, "hello", "namaste"))

/* ── Section 14: todo_lines (split lines) ── */
likho("=== Section 14: todo_lines ===")
maano multiline = "line1\nline2\nline3"
maano lines = todo_lines(multiline)
likho(lines)

/* ── Section 15: to_json ── */
likho("=== Section 15: to_json ===")
likho(to_json(42))
likho(to_json("hello"))
likho(to_json(sach))
likho(to_json(khali))
likho(to_json([1, 2, 3]))

/* ── Section 16: daawa (assert) ── */
likho("=== Section 16: daawa ===")
daawa(sach)
daawa(1 + 1 == 2, "math works")
likho("assertions passed")

/* ── Section 17: kram_ulta (sort descending) ── */
likho("=== Section 17: kram_ulta ===")
maano desc = kram_ulta([3, 1, 4, 1, 5, 9, 2, 6])
likho(desc)

likho("=== ALL PHASE 3 TESTS PASSED ===")
