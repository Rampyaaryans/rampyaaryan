# ============================================
# RAMPYAARYAN MEGA TEST - ALL FEATURES
# ============================================

# 1. VARIABLES & TYPES
likho "=== 1. VARIABLES & TYPES ==="
maano num = 42
maano dec = 3.14
maano naam = "Aryan"
maano flag = sach
maano nothing = khali
maano fruits = ["seb", "kela", "aam"]
maano student = {"naam": "Aryan", "umar": 20}
likho num, dec, naam, flag, nothing
likho prakar(num), prakar(naam), prakar(flag), prakar(nothing), prakar(fruits)

# 2. ARITHMETIC
likho ""
likho "=== 2. ARITHMETIC ==="
likho 10 + 5, 10 - 5, 10 * 5, 10 / 3, 10 % 3, 2 ** 10

# 3. COMPARISON & LOGIC
likho ""
likho "=== 3. COMPARISON & LOGIC ==="
likho 5 == 5, 5 != 3, 5 > 3, 5 < 3, 5 >= 5, 5 <= 4
likho sach aur sach, sach ya jhooth, nahi jhooth

# 4. COMPOUND ASSIGNMENT
likho ""
likho "=== 4. COMPOUND ASSIGNMENT ==="
maano x = 10
x += 5
likho "+=", x
x -= 3
likho "-=", x
x *= 2
likho "*=", x
x /= 4
likho "/=", x

# 5. IF/ELSE
likho ""
likho "=== 5. IF/ELSE ==="
maano age = 20
agar age >= 18 {
    likho "Adult"
} warna agar age >= 13 {
    likho "Teen"
} warna {
    likho "Child"
}

# 6. WHILE LOOP
likho ""
likho "=== 6. WHILE LOOP ==="
maano i = 1
jab tak i <= 5 {
    likho i;
    i += 1
}
likho ""

# 7. FOR LOOP
likho ""
likho "=== 7. FOR LOOP ==="
har j = 1; j <= 5; j = j + 1 {
    likho j;
}
likho ""

# 8. BREAK & CONTINUE
likho ""
likho "=== 8. BREAK & CONTINUE ==="
har k = 1; k <= 10; k = k + 1 {
    agar k == 7 { ruko }
    agar k % 2 == 0 { agla }
    likho k;
}
likho ""

# 9. FUNCTIONS
likho ""
likho "=== 9. FUNCTIONS ==="
kaam greet(naam) {
    likho "Namaste,", naam
}
greet("Rampyaaryan")

kaam add(a, b) {
    wapas do a + b
}
likho "add(3,4) =", add(3, 4)

# 10. RECURSION
likho ""
likho "=== 10. RECURSION ==="
kaam fact(n) {
    agar n <= 1 { wapas do 1 }
    wapas do n * fact(n - 1)
}
likho "10! =", fact(10)

# 11. CLOSURES
likho ""
likho "=== 11. CLOSURES ==="
kaam counter() {
    maano count = 0
    kaam inc() {
        count = count + 1
        wapas do count
    }
    wapas do inc
}
maano c = counter()
likho c(), c(), c()

# 12. TYPE CONVERSION
likho ""
likho "=== 12. TYPE CONVERSION ==="
likho sankhya("42"), shabd(42), purn(3.99), dashmlav("3.14"), bool_val(1)

# 13. TYPE CHECKING
likho ""
likho "=== 13. TYPE CHECKING ==="
likho kya_sankhya(42), kya_shabd("hi"), kya_suchi([1]), kya_bool(sach), kya_khali(khali)
likho kya_purn(42), kya_purn(3.14), kya_map({"a": 1})

# 14. STRING OPERATIONS
likho ""
likho "=== 14. STRING OPERATIONS ==="
maano s = "Namaste Duniya"
likho lambai(s)
likho bade_akshar(s)
likho chhote_akshar(s)
likho kato(s, 0, 7)
likho dhundho(s, "Duniya")
likho badlo(s, "Duniya", "World")
likho dohrao("ha", 3)
likho akshar(s, 0)
likho ascii_code("A")
likho ascii_se(65)
likho format("{} + {} = {}", 1, 2, 3)
likho gino(s, "a")

