# 24. HIGHER-ORDER FUNCTIONS
likho ""
likho "=== 24. HIGHER-ORDER ==="
kaam sq(x) { wapas do x * x }
kaam even(x) { wapas do x % 2 == 0 }
kaam plus(a, b) { wapas do a + b }

maano nums = [1, 2, 3, 4, 5]
likho naksha(nums, sq)
likho chhaano(nums, even)
likho ikkatha(nums, plus, 0)
likho sab([1, 2, 3])
likho koi([0, 0, 1])
likho jodi_banao([1,2,3], ["a","b","c"])
likho ginati_banao(["x","y","z"])

