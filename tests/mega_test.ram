# 17. LIST OPERATIONS
likho ""
likho "=== 17. LIST OPERATIONS ==="
maano lst = [5, 3, 1, 4, 2]
joodo(lst, 6)
likho lst
kram(lst)
likho "sorted:", lst
likho pahla(lst), aakhri(lst)
likho lambai(lst)
likho shamil(lst, 3)
likho index_of(lst, 4)
likho ulta(lst)
likho katao(lst, 0, 3)
likho anokha([1,2,2,3,3,3])
likho jod([1,2,3,4,5])
likho ausat([10,20,30])
likho sabse_bada([5,9,1,7])
likho sabse_chhota([5,9,1,7])

# 18. ADVANCED LISTS
