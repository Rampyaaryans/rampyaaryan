likho "=== COMPREHENSIVE FEATURE TEST ==="

likho "--- 1. Bitwise Assign ---"
maano x = 15
x &= 9
likho x
x |= 6
likho x
x ^= 3
likho x
x <<= 2
likho x
x >>= 1
likho x

likho "--- 2. Map Natives ---"
maano m = {"a": 1, "b": 2, "c": 3}
likho naksha_keys(m)
likho naksha_values(m)
likho naksha_items(m)

likho "--- 3. Map Delete ---"
maano removed = naksha_hatao(m, "b")
likho removed
likho lambai(m)

likho "--- 4. Map Merge ---"
maano m1 = {"x": 10, "y": 20}
maano m2 = {"y": 30, "z": 40}
maano merged = naksha_jodo(m1, m2)
likho merged["x"]
likho merged["y"]
likho merged["z"]

likho "--- 5. Map Length ---"
likho lambai({"a": 1, "b": 2, "c": 3})

likho "--- 6. Assert ---"
pakka 1 == 1
pakka "hello" == "hello"
pakka sach
likho "Assertions passed"

likho "--- 7. In Operator Comprehensive ---"
likho 5 mein [1, 2, 3, 4, 5]
likho "o" mein "hello"
likho "x" mein {"x": 1, "y": 2}

likho "--- 8. Enum with In ---"
ganana Fruit {
    APPLE,
    BANANA,
    CHERRY
}
likho "APPLE" mein Fruit
likho Fruit["CHERRY"]

likho "--- 9. For-In Map ---"
maano data = {"naam": "Ram", "umar": 25}
har k mein data {
    likho k + ": " + shabd(data[k])
}

likho "--- 10. Power Assign ---"
maano base = 2
base **= 8
likho base

likho "=== ALL COMPREHENSIVE TESTS PASSED ==="
