likho "=== ENUM TEST ==="

likho "--- 1. Basic Enum ---"
ganana Direction {
    NORTH,
    SOUTH,
    EAST,
    WEST
}
likho Direction["NORTH"]
likho Direction["SOUTH"]
likho Direction["EAST"]
likho Direction["WEST"]

likho "--- 2. Enum with Explicit Values ---"
ganana Color {
    RED = 10,
    GREEN = 20,
    BLUE = 30
}
likho Color["RED"]
likho Color["GREEN"]
likho Color["BLUE"]

likho "--- 3. Enum Access and Comparison ---"
maano d = Direction["NORTH"]
likho d == 0

maano c = Color["RED"]
likho c == 10

likho "--- 4. Mixed Auto and Explicit ---"
ganana Status {
    PENDING,
    ACTIVE = 5,
    DONE
}
likho Status["PENDING"]
likho Status["ACTIVE"]
likho Status["DONE"]

likho "--- 5. Enum as Map ---"
likho prakar(Direction) == "shabdkosh"

likho "=== ALL ENUM TESTS PASSED ==="
