{
  "name": "rampyaaryan",
  "displayName": "Rampyaaryan - Hinglish Programming Language",
  "description": "Syntax highlighting, Indian themes, Neko cat, Hindi UI, file icons and language support for Rampyaaryan (.ram) — India's First Hinglish Programming Language",
  "version": "3.1.0",
  "publisher": "Rampyaaryans",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "images/icon.png",
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rampyaaryans/rampyaaryan"
  },
  "homepage": "https://rampyaaryans.github.io/rampyaaryan/",
  "bugs": {
    "url": "https://github.com/Rampyaaryans/rampyaaryan/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "rampyaaryan",
    "hinglish",
    "hindi",
    "indian",
    "programming language",
    "ram",
    "theme",
    "neko",
    "cat",
    "diwali",
    "india",
    "devanagari"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rampyaaryan",
        "aliases": [
          "Rampyaaryan",
          "rampyaaryan",
          "ram"
        ],
        "extensions": [
          ".ram"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ram-icon-light.png",
          "dark": "./icons/ram-icon-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "rampyaaryan",
        "scopeName": "source.rampyaaryan",
        "path": "./syntaxes/rampyaaryan.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Jai Shri Ram",
        "uiTheme": "vs-dark",
        "path": "./themes/jai-shri-ram-color-theme.json"
      },
      {
        "label": "Tiranga",
        "uiTheme": "vs-dark",
        "path": "./themes/tiranga-color-theme.json"
      },
      {
        "label": "Diwali Night",
        "uiTheme": "vs-dark",
        "path": "./themes/diwali-night-color-theme.json"
      },
      {
        "label": "Ram Mandir",
        "uiTheme": "vs",
        "path": "./themes/ram-mandir-color-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "rampyaaryan-icons",
        "label": "Rampyaaryan File Icons",
        "path": "./icons/icon-theme.json"
      }
    ],
    "commands": [
      { "command": "rampyaaryan.openNeko", "title": "Rampyaaryan: Open Neko Cat" },
      { "command": "rampyaaryan.namaste", "title": "Rampyaaryan: Namaste!" },
      { "command": "rampyaaryan.toggleHindiStatusBar", "title": "Rampyaaryan: Toggle Hindi Status Bar" },
      { "command": "rampyaaryan.toggleMantra", "title": "Rampyaaryan: Toggle Mantra Mode" },
      { "command": "rampyaaryan.toggleRamQuotes", "title": "Rampyaaryan: Toggle Ram Quotes" },
      { "command": "rampyaaryan.setHindiFont", "title": "Rampyaaryan: Set Hindi/Devanagari Font" },
      { "command": "rampyaaryan.diwaliMode", "title": "Rampyaaryan: Diwali Mode" }
    ],
    "configuration": {
      "title": "Rampyaaryan",
      "properties": {
        "rampyaaryan.hindiStatusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show line/column in Hindi Devanagari numerals in status bar"
        },
        "rampyaaryan.mantra.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show cycling Sanskrit mantras in status bar"
        },
        "rampyaaryan.greeting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Namaste greeting on startup"
        }
      }
    }
  },
  "galleryBanner": {
    "color": "#2c2416",
    "theme": "dark"
  }
}
