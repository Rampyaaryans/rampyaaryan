{
  "name": "Jai Shri Ram 🙏",
  "type": "dark",
  "colors": {
    "editor.background": "#1C1108",
    "editor.foreground": "#F5E6CE",
    "editorCursor.foreground": "#FF9933",
    "editor.lineHighlightBackground": "#2A150530",
    "editor.selectionBackground": "#FF993340",
    "editor.wordHighlightBackground": "#FFD70025",
    "editorLineNumber.foreground": "#6B5B45",
    "editorLineNumber.activeForeground": "#FF9933",
    "editorIndentGuide.background1": "#2A150540",
    "editorBracketMatch.background": "#FFD70030",
    "editorBracketMatch.border": "#FFD70080",

    "activityBar.background": "#1A0E05",
    "activityBar.foreground": "#FF9933",
    "activityBar.activeBorder": "#FF9933",
    "activityBarBadge.background": "#FF9933",
    "activityBarBadge.foreground": "#1C1108",

    "sideBar.background": "#180D04",
    "sideBar.foreground": "#D4C4A8",
    "sideBarTitle.foreground": "#FF9933",
    "sideBarSectionHeader.background": "#2A150580",
    "sideBarSectionHeader.foreground": "#FFD700",

    "titleBar.activeBackground": "#2A1505",
    "titleBar.activeForeground": "#F5E6CE",
    "titleBar.inactiveBackground": "#1A0E05",

    "statusBar.background": "#CC7A29",
    "statusBar.foreground": "#FFFFFF",
    "statusBar.debuggingBackground": "#FF4500",
    "statusBar.noFolderBackground": "#8B4513",
    "statusBarItem.hoverBackground": "#FF993380",

    "tab.activeBackground": "#1C1108",
    "tab.activeForeground": "#FFD700",
    "tab.inactiveBackground": "#140C05",
    "tab.inactiveForeground": "#8B7B65",
    "tab.activeBorderTop": "#FF9933",
    "editorGroupHeader.tabsBackground": "#140C05",

    "input.background": "#2A150590",
    "input.foreground": "#F5E6CE",
    "input.border": "#FF993360",
    "input.placeholderForeground": "#8B7B6580",
    "focusBorder": "#FF9933",

    "button.background": "#FF9933",
    "button.foreground": "#1C1108",
    "button.hoverBackground": "#FFB347",

    "dropdown.background": "#1A0E05",
    "dropdown.border": "#FF993340",

    "list.activeSelectionBackground": "#FF993330",
    "list.activeSelectionForeground": "#FFD700",
    "list.hoverBackground": "#2A150540",
    "list.focusBackground": "#FF993320",

    "terminal.background": "#1C1108",
    "terminal.foreground": "#F5E6CE",
    "terminal.ansiYellow": "#FFD700",
    "terminal.ansiRed": "#FF4500",
    "terminal.ansiGreen": "#8B9A46",
    "terminal.ansiBlue": "#C0A060",
    "terminal.ansiCyan": "#DAA520",

    "panel.background": "#180D04",
    "panel.border": "#2A150580",
    "panelTitle.activeForeground": "#FF9933",
    "panelTitle.activeBorder": "#FF9933",

    "badge.background": "#FF9933",
    "badge.foreground": "#1C1108",
    "scrollbarSlider.background": "#FF993320",
    "scrollbarSlider.hoverBackground": "#FF993340",
    "minimap.selectionHighlight": "#FF993360"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#8B7355", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted"], "settings": { "foreground": "#FFD700" } },
    { "scope": "string.regexp", "settings": { "foreground": "#DAA520" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#F4A460" } },
    { "scope": "constant.language", "settings": { "foreground": "#FF6B35", "fontStyle": "italic" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#CD853F" } },
    { "scope": ["keyword", "keyword.control"], "settings": { "foreground": "#FF9933", "fontStyle": "bold" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#CC7A29" } },
    { "scope": ["storage.type", "storage.modifier"], "settings": { "foreground": "#FF8C00", "fontStyle": "italic" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#FFA500" } },
    { "scope": "entity.name.class", "settings": { "foreground": "#FFD700", "fontStyle": "bold" } },
    { "scope": "entity.name.type", "settings": { "foreground": "#DAA520" } },
    { "scope": "variable", "settings": { "foreground": "#F5E6CE" } },
    { "scope": "variable.parameter", "settings": { "foreground": "#DEB887", "fontStyle": "italic" } },
    { "scope": "variable.other.property", "settings": { "foreground": "#D2B48C" } },
    { "scope": "punctuation", "settings": { "foreground": "#C0A070" } },
    { "scope": "meta.function-call", "settings": { "foreground": "#FFA500" } },
    { "scope": "support.class", "settings": { "foreground": "#FFD700" } },
    { "scope": "markup.heading", "settings": { "foreground": "#FF9933", "fontStyle": "bold" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#DAA520" } }
  ]
}
